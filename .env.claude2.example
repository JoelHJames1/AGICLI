# ============================================================================
# Claude2 — AGI-Oriented Agent CLI Configuration
# ============================================================================
# Copy this file to .env.claude2 and fill in your API keys.
# Only configure the providers you want to use.

# ============================================================================
# Provider Selection
# ============================================================================
# Auto-detected from available API keys if not set.
# Options: anthropic, openai, gemini, ollama, openai-compatible
# CLAUDE2_PROVIDER=anthropic

# ============================================================================
# Anthropic (Claude) — Default Provider
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-6
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Anthropic Cloud Variants (set ONE):
# CLAUDE_CODE_USE_BEDROCK=true     # AWS Bedrock
# CLAUDE_CODE_USE_VERTEX=true      # Google Vertex AI
# CLAUDE_CODE_USE_FOUNDRY=true     # Azure Foundry

# ============================================================================
# OpenAI (GPT-4o, o3, etc.)
# ============================================================================
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================================
# Google Gemini (1M context window)
# ============================================================================
# GOOGLE_GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# ============================================================================
# Ollama (Local/Private Models — no data leaves your machine)
# ============================================================================
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:70b

# ============================================================================
# OpenAI-Compatible (Together AI, Groq, LiteLLM, vLLM, Fireworks)
# ============================================================================
# OPENAI_COMPATIBLE_BASE_URL=https://api.together.xyz/v1
# OPENAI_COMPATIBLE_API_KEY=...
# OPENAI_COMPATIBLE_MODEL=meta-llama/Llama-3-70b-chat-hf

# ============================================================================
# Smart Model Router — Use Best Model Per Task
# ============================================================================
# CLAUDE2_MODEL_ROUTER=true
#
# Per-task model preferences (optional):
# AGENT_CODING_MODEL=claude-opus-4-6
# AGENT_REASONING_MODEL=o3
# AGENT_FAST_MODEL=claude-haiku-4-5
# AGENT_LOCAL_MODEL=ollama/codestral
# AGENT_LONG_CONTEXT_MODEL=gemini-2.5-flash

# ============================================================================
# AGI Features
# ============================================================================
# CLAUDE2_REFLECTION=true          # Enable reflection & self-correction
# CLAUDE2_PLANNER=true             # Enable strategic planner
# CLAUDE2_WATCHERS=true            # Enable file/git/CI watchers
# CLAUDE2_SELF_IMPROVE=true        # Enable self-improvement pipeline
# CLAUDE2_KNOWLEDGE_GRAPH=true     # Enable code knowledge graph

# ============================================================================
# General
# ============================================================================
# API_TIMEOUT_MS=600000            # API call timeout (default: 10 minutes)
# ANTHROPIC_CUSTOM_HEADERS=        # Custom headers (multiline "Name: Value")
